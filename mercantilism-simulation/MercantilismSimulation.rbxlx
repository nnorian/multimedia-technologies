-- Nation rows (created for each nation)
local nationRows = {}

local function createNationRows()
    -- Remove old rows
    for _, row in ipairs(nationRows) do
        row.frame:Destroy()
    end
    nationRows = {}

    for i, nationData in ipairs(Config.NATIONS) do
        local rowY = 35 + (i - 1) * 92
        local rowFrame = makeFrame({
            Name                  = "NationRow_" .. nationData.id,
            Size                  = UDim2.new(1, -16, 0, 86),
            Position              = UDim2.new(0, 8, 0, rowY),
            BackgroundColor3      = Color3.fromRGB(25, 25, 40),
            BackgroundTransparency = 0.3,
            Parent                = leaderboardPanel,
        })
        do
            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(0, 4)
            corner.Parent = rowFrame
        end

        -- Nation color square
        local colorSquare = makeFrame({
            Name                  = "ColorSquare",
            Size                  = UDim2.new(0, 14, 0, 14),
            Position              = UDim2.new(0, 8, 0, 8),
            BackgroundColor3      = nationData.color,
            BackgroundTransparency = 0,
            Parent                = rowFrame,
        })
        do
            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(0, 3)
            corner.Parent = colorSquare
        end

        -- Nation name
        local nameLabel = makeLabel({
            Name       = "NationName",
            Size       = UDim2.new(0.55, 0, 0, 20),
            Position   = UDim2.new(0, 28, 0, 4),
            Text       = nationData.name,
            TextColor3 = COLORS.WHITE,
            Font       = Enum.Font.GothamBold,
            TextSize   = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent     = rowFrame,
        })

        -- Degradation status badge (top-right of row)
        local statusBadge = makeLabel({
            Name       = "StatusBadge",
            Size       = UDim2.new(0.42, 0, 0, 16),
            Position   = UDim2.new(0.57, 0, 0, 6),
            Text       = "● HEALTHY",
            TextColor3 = COLORS.GREEN,
            Font       = Enum.Font.GothamBold,
            TextSize   = 10,
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent     = rowFrame,
        })

        -- Wealth label (large, right-aligned)
        local wealthLabel = makeLabel({
            Name       = "WealthLabel",
            Size       = UDim2.new(1, -12, 0, 22),
            Position   = UDim2.new(0, 6, 0, 24),
            Text       = "1,000 g",
            TextColor3 = COLORS.GOLD,
            Font       = Enum.Font.GothamBold,
            TextSize   = 16,
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent     = rowFrame,
        })

        -- Trade balance label
        local balanceLabel = makeLabel({
            Name       = "BalanceLabel",
            Size       = UDim2.new(0.5, -6, 0, 18),
            Position   = UDim2.new(0, 6, 0, 48),
            Text       = "Balance: +0",
            TextColor3 = COLORS.LIGHT_GRAY,
            Font       = Enum.Font.Gotham,
            TextSize   = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent     = rowFrame,
        })

        -- Navy cost label
        local navyLabel = makeLabel({
            Name       = "NavyLabel",
            Size       = UDim2.new(0.5, -6, 0, 18),
            Position   = UDim2.new(0.5, 0, 0, 48),
            Text       = "Navy: 20g",
            TextColor3 = COLORS.LIGHT_GRAY,
            Font       = Enum.Font.Gotham,
            TextSize   = 11,
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent     = rowFrame,
        })

        -- Warships label
        local warshipsLabel = makeLabel({
            Name       = "WarshipsLabel",
            Size       = UDim2.new(1, -12, 0, 14),
            Position   = UDim2.new(0, 6, 0, 68),
            Text       = "Ships: 2T / 1W",
            TextColor3 = Color3.fromRGB(150, 150, 170),
            Font       = Enum.Font.Gotham,
            TextSize   = 10,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent     = rowFrame,
        })

        table.insert(nationRows, {
            nationId      = nationData.id,
            frame         = rowFrame,
            wealthLabel   = wealthLabel,
            balanceLabel  = balanceLabel,
            navyLabel     = navyLabel,
            warshipsLabel = warshipsLabel,
            statusBadge   = statusBadge,
        })
    end
end

