    TextColor3 = COLORS.LIGHT_GRAY,
    Font       = Enum.Font.Gotham,
    TextSize   = 11,
    TextYAlignment = Enum.TextYAlignment.Top,
    ZIndex     = 11,
    Parent     = comparisonPanel,
})

-- Free trade column content
local freeGlobalLabel = makeLabel({
